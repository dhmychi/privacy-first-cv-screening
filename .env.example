# Copy to .env and set a strong random value. Clients send this as the X-API-Key header.
CV_API_KEY=change-me-to-a-long-random-string

# Backend mode:
#   mock   = deterministic, zero-dependency demo (DEFAULT). Runs the whole
#            pipeline with NO model, NO Ollama and NO network; results are clearly
#            labelled as mock, not real model inference.
#   ollama = use the local models below (set CV_OLLAMA_URL / CV_LLM_MODEL /
#            CV_EMBED_MODEL to a reachable on-box Ollama).
CV_LLM_MODE=mock
