# --- Secrets / local config (NEVER commit) ---
.env
.env.*
!.env.example
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

